	<select id="list" resultType="com.hot.modules.hot.entity.HotCoop">
		SELECT
			a.id,
			a.doc_num AS 'docNum',
			a.bd_name AS 'bdName',
			a.conn_time AS 'connTime',
			a.agcc_time AS 'agccTime',
			a.hotb_id AS 'hotbId',
			a.hots_id AS 'hotsId',
			a.channel,
			a.country,
			a.invit_id AS 'invitId',
			b.doc_num AS 'invitDocNum',
			a.project_id AS 'projectId',
			c.name AS 'projectName',
			a.state,
			d.label AS 'states'
		FROM a_hot_coop a
		LEFT JOIN `a_hot_invit` b ON b.id = a.invit_id
		LEFT JOIN `a_project` c ON c.id = a.project_id
		LEFT JOIN `sys_dict` d ON d.value = a.state AND d.type = 'hot_state' AND d.del_flag = 0
		WHERE a.del_flag = 0
		<if test="country != null and country != ''">
			AND a.`country` LIKE CONCAT('%',#{country},'%')
		</if>
		<if test="bdName != null and bdName != ''">
			AND a.`bd_name` LIKE CONCAT('%',#{bdName},'%')
		</if>
		<if test="state != null and state != ''">
			AND a.`state` = #{state}
		</if>
		<if test="channel != null and channel != ''">
			AND a.`channel` = #{channel}
		</if>
		<if test="hotsId != null and hotsId != ''">
			AND a.`hots_id` LIKE CONCAT('%',#{hotsId},'%')
		</if>
		<if test="projectName != null and projectName != ''">
			AND c.name LIKE CONCAT('%',#{projectName},'%')
		</if>
		ORDER BY id DESC
	</select>

	<insert id="insert" parameterType="com.hot.modules.hot.entity.HotCoop" useGeneratedKeys="true" keyProperty="id">
		INSERT INTO `a_hot_coop` (
			`doc_num`,
			`bd_name`,
			`conn_time`,
			`agcc_time`,
			`hotb_id`,
			`hots_id`,
			`channel`,
			`country`,
			`invit_id`,
			`project_id`,
			`create_user`,
			`create_time`,
			`update_user`,
			`update_time`
		) VALUES (
			#{docNum},
			#{bdName},
			#{connTime},
			#{agccTime},
			#{hotbId},
			#{hotsId},
			#{channel},
			#{country},
			#{invitId},
			#{projectId},
			#{createUser},
			NOW(),
			#{updateUser},
			NOW()
		)
	</insert>

	<update id="update" parameterType="com.hot.modules.hot.entity.HotCoop">
		UPDATE `a_hot_coop` SET
			`conn_time` = #{connTime},
			`agcc_time` = #{agccTime},
			`hotb_id` = #{hotbId},
			`hots_id` = #{hotsId},
			`channel` = #{channel},
			`country` = #{country},
			`invit_id` = #{invitId},
			`project_id` = #{projectId},
			`update_user` = #{updateUser},
			`update_time` = NOW()
		WHERE id = #{id}
	</update>

	<update id="delete">
		UPDATE `a_hot_coop` SET
			`del_flag` = 1,
			`update_user` = #{userid},
			`update_time` = NOW()
		WHERE id = #{id}
	</update>

	<update id="close">
		UPDATE `a_hot_coop` SET
			`state` = 2,
			`update_user` = #{userid},
			`update_time` = NOW()
		WHERE id = #{id}
	</update>

	<update id="deleteList">
		call coop_deleteList(#{userid}, #{id})
	</update>

