<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hot.modules.sys.dao.BasicDao">

	<select id="tree" resultType="com.hot.modules.sys.entity.BasicTree">
		CALL basic_tree(#{userid},#{name},#{param});
	</select>

	<select id="data" resultType="java.util.Map">
		CALL basic_data(#{userid},#{name},#{param});
	</select>

	<select id="user" resultType="com.hot.modules.sys.entity.SysUser">
		CALL basic_user(#{id});
	</select>

	<select id="menu" resultType="com.hot.modules.sys.entity.SysMenu">
		CALL basic_menu(#{userid},#{type});
	</select>

	<resultMap id="moduMap" type="com.hot.modules.sys.entity.SysMenu">
		<id property="id" column="id"/>
		<result property="parentId" column="parent_id"/>
		<result property="title" column="title"/>
		<result property="path" column="path"/>
		<result property="component" column="component"/>
		<result property="sign" column="sign"/>
		<result property="icon" column="icon"/>
		<result property="sort" column="sort"/>
		<result property="type" column="type"/>
		<collection property="modu" ofType="com.hot.modules.sys.entity.SysModu">
			<id property="id" column="modu.id"/>
			<result property="title" column="modu.title"/>
			<result property="path" column="modu.path"/>
			<result property="component" column="modu.component"/>
			<result property="sign" column="modu.sign"/>
			<result property="icon" column="modu.icon"/>
			<result property="sort" column="modu.sort"/>
		</collection>
	</resultMap>

	<select id="modu" resultMap="moduMap">
		CALL basic_modu(#{userid},#{type});
	</select>

	<resultMap id="buttMap" type="com.hot.modules.sys.entity.SysMenu">
		<id property="id" column="id"/>
		<result property="parentId" column="parent_id"/>
		<result property="title" column="title"/>
		<result property="path" column="path"/>
		<result property="component" column="component"/>
		<result property="sign" column="sign"/>
		<result property="icon" column="icon"/>
		<result property="sort" column="sort"/>
		<result property="type" column="type"/>
		<collection property="butt" ofType="com.hot.modules.sys.entity.SysButt">
			<id property="id" column="butt.id"/>
			<result property="title" column="butt.title"/>
			<result property="sign" column="butt.sign"/>
			<result property="icon" column="butt.icon"/>
			<result property="sort" column="butt.sort"/>
		</collection>
	</resultMap>

	<select id="butt" resultMap="buttMap">
		CALL basic_butt(#{userid},#{type});
	</select>

</mapper>